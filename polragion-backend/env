# Application
APP_NAME="Polragion Backend"
LOG_LEVEL=INFO

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_PREFIX=polragion
QDRANT_BATCH_SIZE=256
QDRANT_PARALLEL=4

# Embeddings
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
INDEX_SCHEMA_VERSION=1

# Search
SEARCH_DEFAULT_LIMIT=5
SEARCH_MAX_LIMIT=100

# Optional: Leave unset to disable the minimum score threshold.
# Do not set this to an empty value, because an empty string cannot be parsed as float | None.
# SEARCH_SCORE_THRESHOLD=0.30

# Ingestion
MAX_INGEST_BATCH_SIZE=2500
